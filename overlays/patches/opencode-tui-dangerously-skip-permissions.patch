From 7399fcb3fb64dc4e6f53155fdb69544bb813eb9b Mon Sep 17 00:00:00 2001
From: Craig Barber <craigb@mojotech.com>
Date: Thu, 11 Jun 2026 01:40:21 +0000
Subject: [PATCH] feat(tui): add --dangerously-skip-permissions to TUI command

The flag existed on `opencode run` but not the default TUI command,
so passing it at launch silently had no effect.

Authored-By: opencode (anthropic/claude-sonnet-4-6)
---
 packages/opencode/src/cli/cmd/tui.ts | 6 ++++++
 packages/tui/src/context/args.tsx    | 1 +
 packages/tui/src/context/sync.tsx    | 7 +++++++
 3 files changed, 14 insertions(+)

diff --git a/packages/opencode/src/cli/cmd/tui.ts b/packages/opencode/src/cli/cmd/tui.ts
index 68941e9..861256a 100644
--- a/packages/opencode/src/cli/cmd/tui.ts
+++ b/packages/opencode/src/cli/cmd/tui.ts
@@ -103,6 +103,11 @@ export const TuiThreadCommand = cmd({
       .option("agent", {
         type: "string",
         describe: "agent to use",
+      })
+      .option("dangerously-skip-permissions", {
+        type: "boolean",
+        describe: "auto-approve permissions that are not explicitly denied (dangerous!)",
+        default: false,
       }),
   handler: async (args) => {
     const unguard = win32InstallCtrlCGuard()
@@ -207,6 +212,7 @@ export const TuiThreadCommand = cmd({
               model: args.model,
               prompt,
               fork: args.fork,
+              dangerouslySkipPermissions: args["dangerously-skip-permissions"],
             },
           }),
         )
diff --git a/packages/tui/src/context/args.tsx b/packages/tui/src/context/args.tsx
index 8a229ff..316570f 100644
--- a/packages/tui/src/context/args.tsx
+++ b/packages/tui/src/context/args.tsx
@@ -7,6 +7,7 @@ export interface Args {
   continue?: boolean
   sessionID?: string
   fork?: boolean
+  dangerouslySkipPermissions?: boolean
 }
 
 export const { use: useArgs, provider: ArgsProvider } = createSimpleContext({
diff --git a/packages/tui/src/context/sync.tsx b/packages/tui/src/context/sync.tsx
index 4882c13..7150ec4 100644
--- a/packages/tui/src/context/sync.tsx
+++ b/packages/tui/src/context/sync.tsx
@@ -181,6 +181,13 @@ export const {
 
         case "permission.asked": {
           const request = event.properties
+          if (args.dangerouslySkipPermissions) {
+            void sdk.client.permission.reply({
+              requestID: request.id,
+              reply: "once",
+            })
+            break
+          }
           const requests = store.permission[request.sessionID]
           if (!requests) {
             setStore("permission", request.sessionID, [request])
-- 
2.53.0

