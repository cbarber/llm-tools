#!/usr/bin/env bash
# Git credential helper for nixsmith-managed tokens.
# Git calls credential helpers with an action argument (get/store/erase).
# We only handle "get"; other actions are silently ignored.
#
# The token file path is resolved from GITHUB_TOKEN_FILE (set by
# setup-sandbox-paths.sh to point to the per-org token for the current repo).
TOKEN_FILE="${GITHUB_TOKEN_FILE:-${HOME}/.config/nixsmith/github-token}"

[[ "${1:-}" != "get" ]] && exit 0
[[ -f "$TOKEN_FILE" ]] || exit 1

printf "username=x-access-token\npassword=%s\n" "$(cat "$TOKEN_FILE")"
