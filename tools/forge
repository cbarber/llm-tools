#!/usr/bin/env bash
# Unified GitHub/Gitea CLI wrapper for agent workflows
# Provides LCD (Lowest Common Denominator) commands that work across both forges

set -euo pipefail

NIXSMITH_CONFIG="${HOME}/.config/nixsmith"

# shellcheck source=common-helpers.sh
source "$(dirname "$0")/common-helpers.sh"

# Wrapper for tea that uses nixsmith namespace
run_tea() {
    XDG_CONFIG_HOME="${NIXSMITH_CONFIG}" tea "$@"
}

# Detect forge type from git remote
detect_forge() {
    local remote_url
    remote_url=$(git remote get-url origin 2>/dev/null || echo "")
    
    if [[ "$remote_url" =~ github\.com ]]; then
        echo "github"
    elif [[ "$remote_url" =~ gitlab\.com ]]; then
        echo "gitlab"
    elif [[ "$remote_url" =~ gitea ]]; then
        echo "gitea"
    else
        echo "unknown"
    fi
}

# Authenticate GitHub
authenticate_github() {
    local token_file
    token_file=$(nixsmith_github_token_file 2>/dev/null || true)

    if [[ -n "$token_file" ]] && [[ -f "$token_file" ]]; then
        GH_TOKEN=$(cat "$token_file")
        export GH_TOKEN
    elif [[ -f "${NIXSMITH_CONFIG}/github-token" ]]; then
        # Legacy single-token fallback — only reached if migration has not run.
        GH_TOKEN=$(cat "${NIXSMITH_CONFIG}/github-token")
        export GH_TOKEN
    elif gh auth status &>/dev/null 2>&1; then
        echo "⚠️  Warning: Using dev's gh auth. Set up agent tokens: tools/setup-agent-api-tokens.sh" >&2
    else
        echo "Error: No GitHub authentication." >&2
        echo "Run: tools/setup-agent-api-tokens.sh" >&2
        exit 1
    fi
}

# Authenticate Gitea
authenticate_gitea() {
    if ! run_tea repos list >/dev/null 2>&1; then
        echo "Error: Gitea not authenticated." >&2
        echo "Run: tools/setup-agent-api-tokens.sh" >&2
        exit 1
    fi
}

FORGE_TYPE=$(detect_forge)

# doctor runs before authentication — it is the tool used to diagnose auth
# failures, so it must not require auth to start.
if [[ "${1:-}" != "doctor" ]]; then
    # Ensure we have the right CLI tool and authenticate
    case "$FORGE_TYPE" in
        github)
            if ! command -v gh >/dev/null; then
                echo "Error: gh CLI not found. Install with: nix-env -iA nixpkgs.gh" >&2
                exit 1
            fi
            authenticate_github
            ;;
        gitea)
            if ! command -v tea >/dev/null; then
                echo "Error: tea CLI not found. Install with: nix-env -iA nixpkgs.tea" >&2
                exit 1
            fi
            authenticate_gitea
            ;;
        *)
            echo "Error: Unknown forge type. Remote must be GitHub or Gitea." >&2
            exit 1
            ;;
    esac
fi

auto_detect_pr() {
    local branch
    branch=$(git branch --show-current 2>/dev/null || echo "")
    
    if [[ -z "$branch" ]]; then
        echo "Error: Not on a branch (detached HEAD?)" >&2
        return 1
    fi
    
    case "$FORGE_TYPE" in
        github)
            # Try to find PR for current branch
            local pr_number
            pr_number=$(gh pr list --head "$branch" --json number --jq '.[0].number' 2>/dev/null || echo "")
            
            if [[ -z "$pr_number" ]]; then
                echo "Error: No PR found for branch '$branch'. Create one with: forge pr create" >&2
                return 1
            fi
            
            echo "$pr_number"
            ;;
        gitea)
            # tea doesn't have --head flag, need to parse list output
            local pr_number
            pr_number=$(run_tea pr list --output simple | grep -E "^[0-9]+" | while read -r num title rest; do
                local pr_branch
                pr_branch=$(run_tea pr "$num" --output simple 2>/dev/null | grep -E "^Head Branch:" | cut -d: -f2 | xargs)
                if [[ "$pr_branch" == "$branch" ]]; then
                    echo "$num"
                    break
                fi
            done)
            
            if [[ -z "$pr_number" ]]; then
                echo "Error: No PR found for branch '$branch'. Create one with: forge pr create" >&2
                return 1
            fi
            
            echo "$pr_number"
            ;;
    esac
}

doctor() {
    local ok="  OK  " warn=" WARN " fail=" FAIL "
    local pass=0 warnings=0 failures=0

    check_ok()   { echo "[${ok}] $*";   ((pass++))     || true; }
    check_warn() { echo "[${warn}] $*"; ((warnings++)) || true; }
    check_fail() { echo "[${fail}] $*"; ((failures++)) || true; }

    echo "forge doctor — sandbox health check"
    echo "====================================="
    echo ""

    # ── 1. Git state ───────────────────────────────────────────────────────
    echo "Git"
    local branch upstream ahead behind dirty
    branch=$(git branch --show-current 2>/dev/null || echo "")
    if [[ -z "$branch" ]]; then
        check_warn "branch: detached HEAD"
    else
        check_ok "branch: ${branch}"
    fi

    upstream=$(git rev-parse --abbrev-ref --symbolic-full-name "@{u}" 2>/dev/null || echo "")
    if [[ -n "$upstream" ]]; then
        read -r ahead behind < <(git rev-list --left-right --count "${upstream}...HEAD" 2>/dev/null || echo "0 0")
        check_ok "upstream: ${upstream} (ahead ${ahead}, behind ${behind})"
    else
        check_warn "upstream: no tracking branch set"
    fi

    dirty=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ')
    if [[ "$dirty" -eq 0 ]]; then
        check_ok "working tree: clean"
    else
        check_warn "working tree: ${dirty} modified file(s)"
    fi
    echo ""

    # ── 2. GitHub auth ─────────────────────────────────────────────────────
    echo "GitHub auth"
    local gh_owner token_file
    gh_owner=$(extract_github_owner 2>/dev/null || true)

    if [[ -z "$gh_owner" ]]; then
        check_warn "owner: not a GitHub remote (skipping auth checks)"
    else
        check_ok "owner: ${gh_owner}"
        token_file="${HOME}/.config/nixsmith/github-token-${gh_owner}"

        if [[ -f "$token_file" ]] && [[ -r "$token_file" ]]; then
            check_ok "token file: ${token_file}"
        else
            check_fail "token file: ${token_file} (missing or unreadable)"
        fi

        # Live network check — always performed
        local auth_out auth_user
        if auth_out=$(GH_TOKEN=$(cat "$token_file" 2>/dev/null || true) gh auth status 2>&1); then
            auth_user=$(echo "$auth_out" | grep -oE 'Logged in to github\.com account [^ ]+' | awk '{print $NF}' || true)
            check_ok "gh auth status: ok${auth_user:+ (${auth_user})}"
        else
            check_fail "gh auth status: failed — ${auth_out}"
        fi
    fi
    echo ""

    # ── 3. Required tools in PATH ──────────────────────────────────────────
    echo "Tools"
    local tool ver
    for tool in git bd bun temper gh; do
        if command -v "$tool" >/dev/null 2>&1; then
            case "$tool" in
                git)    ver=$(git --version 2>/dev/null | awk '{print $3}') ;;
                bd)     ver=$(bd --version 2>/dev/null | head -1 || echo "?") ;;
                bun)    ver=$(bun --version 2>/dev/null || echo "?") ;;
                temper) ver=$(temper --version 2>/dev/null || echo "present") ;;
                gh)     ver=$(gh --version 2>/dev/null | head -1 | awk '{print $3}') ;;
                *)      ver="present" ;;
            esac
            check_ok "${tool}: ${ver}"
        else
            check_fail "${tool}: not found in PATH"
        fi
    done
    echo ""

    # ── 4. Sandbox env vars ────────────────────────────────────────────────
    echo "Sandbox"
    if [[ -n "${IN_AGENT_SANDBOX:-}" ]]; then
        check_ok "IN_AGENT_SANDBOX: ${IN_AGENT_SANDBOX}"
    else
        check_warn "IN_AGENT_SANDBOX: not set (running outside sandbox)"
    fi

    for var in OPENCODE_SESSION_ID BD_BRANCH; do
        if [[ -n "${!var:-}" ]]; then
            check_ok "${var}: ${!var}"
        else
            check_warn "${var}: not set"
        fi
    done

    if [[ -n "${NIXSMITH_SANDBOX_RO:-}" ]]; then
        echo ""
        echo "  Read-only mounts:"
        IFS=: read -ra _ro_mounts <<< "${NIXSMITH_SANDBOX_RO}"
        for p in "${_ro_mounts[@]}"; do
            [[ -n "$p" ]] && echo "    ro  $p"
        done
    fi
    if [[ -n "${NIXSMITH_SANDBOX_RW:-}" ]]; then
        echo ""
        echo "  Read-write mounts:"
        IFS=: read -ra _rw_mounts <<< "${NIXSMITH_SANDBOX_RW}"
        for p in "${_rw_mounts[@]}"; do
            [[ -n "$p" ]] && echo "    rw  $p"
        done
    fi
    echo ""

    # ── 5. Filesystem probes ───────────────────────────────────────────────
    echo "Filesystem"
    local probe
    probe="$(pwd)/.nixsmith-doctor-probe"
    if touch "$probe" 2>/dev/null && rm -f "$probe" 2>/dev/null; then
        check_ok "project dir writable: $(pwd)"
    else
        check_fail "project dir not writable: $(pwd)"
    fi

    if [[ -n "${gh_owner:-}" ]]; then
        local tf="${HOME}/.config/nixsmith/github-token-${gh_owner}"
        if [[ -r "$tf" ]]; then
            check_ok "token file readable: ${tf}"
        else
            check_fail "token file not readable: ${tf}"
        fi
    fi

    if [[ -d "${HOME}/.agents/skills" ]]; then
        check_ok "skills dir: ${HOME}/.agents/skills"
    else
        check_warn "skills dir: ${HOME}/.agents/skills (not found)"
    fi
    echo ""

    # ── 6. Beads state ─────────────────────────────────────────────────────
    echo "Beads"
    if command -v bd >/dev/null 2>&1; then
        local stats
        if stats=$(bd stats --json 2>/dev/null); then
            local open blocked
            if command -v jq >/dev/null 2>&1; then
                open=$(echo "$stats"    | jq -r '.summary.open_issues'    2>/dev/null || echo "?")
                blocked=$(echo "$stats" | jq -r '.summary.blocked_issues' 2>/dev/null || echo "?")
            else
                open=$(echo "$stats"    | grep -o '"open_issues": *[0-9]*'    | grep -o '[0-9]*$' || echo "?")
                blocked=$(echo "$stats" | grep -o '"blocked_issues": *[0-9]*' | grep -o '[0-9]*$' || echo "?")
            fi
            check_ok "issues: ${open} open, ${blocked} blocked"
        else
            check_warn "bd stats failed (no beads repo?)"
        fi
    else
        check_warn "bd not in PATH — skipping beads checks"
    fi
    echo ""

    # ── Summary ────────────────────────────────────────────────────────────
    echo "====================================="
    echo "  OK: ${pass}  WARN: ${warnings}  FAIL: ${failures}"
    echo "====================================="

    [[ "$failures" -eq 0 ]]
}

# Show usage
usage() {
    cat <<EOF
Usage: forge <command> [options]

Unified CLI for GitHub (gh) and Gitea (tea) operations.
Auto-detects forge type from git remote.

Commands:
  doctor                       Sandbox health check (git, auth, tools, mounts)

  pr create --title TITLE --body BODY [--draft]
  pr view [NUMBER] [--json]
  pr ci [NUMBER] [--timeout SECONDS]
  pr logs [NUMBER]
  pr comment [NUMBER] TEXT
  pr comments [NUMBER] [--json]
  pr list [--state STATE]
  pr checkout [NUMBER]
  pr approve [NUMBER]
  pr reviews [NUMBER] [--json]
  pr review-reply [NUMBER] COMMENT_ID TEXT
  pr next-action

  issue list [--state STATE]
  issue show NUMBER

Options:
  --json           Output in JSON format (where supported)
  --state STATE    Filter by state: open, closed, all (space-separated)

Note: Use space-separated arguments (e.g., --state open, not --state=open)

Examples:
  forge pr create --title "Fix bug" --body "Description"
  forge pr list --state open --json
  forge pr view 123
  forge pr comments 123
  forge pr review-reply 123 456789 "Fixed in commit abc123"
  forge pr comment 123 "Looks good!"
  forge pr approve 123

Current forge: $FORGE_TYPE
EOF
}

# Returns 0 if the branch has any LLM-authored commits without a Reviewed-By trailer.
# Handles both "Authored-By:" (current standard) and "Authored By:" (legacy prose format).
has_unreviewed_llm_commits() {
    local default_branch
    default_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@refs/remotes/origin/@@')
    local range="origin/${default_branch}..HEAD"

    while IFS= read -r sha; do
        local body
        body=$(git log -1 --format="%B" "$sha")
        if echo "$body" | grep -qiE "^Authored-By:|^Authored By:"; then
            if ! echo "$body" | grep -qiE "^Reviewed-By:"; then
                return 0
            fi
        fi
    done < <(git log --format="%H" "$range" 2>/dev/null)

    return 1
}

# PR commands
pr_create() {
    local title="" body="" draft=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --title) title="$2"; shift 2 ;;
            --body) body="$2"; shift 2 ;;
            --draft) draft=true; shift ;;
            --title=*|--body=*)
                echo "Error: Use space-separated arguments (e.g., --title 'text', not --title='text')" >&2
                exit 1
                ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done

    if [[ -z "$title" ]]; then
        echo "Error: --title required" >&2
        exit 1
    fi

    # PRs with unreviewed LLM commits need human review before teammates see them.
    if has_unreviewed_llm_commits; then
        draft=true
    fi

    # Add agent signature if in agent environment
    if [[ -n "${IN_AGENT_SANDBOX:-}" ]] || [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        body="${body}

---
*🤖 Created by agent*"
    fi

    # Show PR workflow guidelines
    if command -v temper >/dev/null 2>&1 && [[ -f AGENTS.md ]]; then
        echo "📋 PR Creation Guidelines:"
        echo ""
        temper pr
        echo ""
        echo "Creating PR..."
        echo ""
    fi

    local pr_url=""
    case "$FORGE_TYPE" in
        github)
            local args=(--title "$title" --head "$(git branch --show-current)")
            [[ -n "$body" ]] && args+=(--body "$body")
            [[ "$draft" == true ]] && args+=(--draft)
            pr_url=$(gh pr create "${args[@]}")
            echo "$pr_url"
            ;;
        gitea)
            local args=(--title "$title")
            [[ -n "$body" ]] && args+=(--description "$body")
            [[ "$draft" == true ]] && args+=(--draft)
            run_tea pr create "${args[@]}"
            return
            ;;
    esac

    # Apply needs-human-review label when unreviewed LLM commits are present.
    # Label signals to teammates that this PR requires the author's review first.
    if [[ "$FORGE_TYPE" == "github" ]] && has_unreviewed_llm_commits; then
        gh pr edit --add-label "needs-human-review" 2>/dev/null || true
    fi
}

pr_view() {
    local number="${1:-}"
    [[ -n "$number" ]] && shift
    
    # Auto-detect PR if no number provided
    if [[ -z "$number" ]]; then
        number=$(auto_detect_pr) || exit 1
    fi
    
    local json_output=false json_fields=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)
                json_output=true
                # If next arg doesn't start with --, treat it as fields
                if [[ $# -gt 1 ]] && [[ ! "$2" =~ ^-- ]]; then
                    json_fields="$2"
                    shift
                fi
                shift
                ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    
    case "$FORGE_TYPE" in
        github)
            if [[ "$json_output" == true ]]; then
                local fields="${json_fields:-body,title,state,number}"
                gh pr view "$number" --json "$fields"
            else
                # Show PR metadata
                gh pr view "$number"
                
                # Always show comments
                echo ""
                echo "Comments:"
                echo ""
                pr_comments "$number"
            fi
            ;;
        gitea)
            if [[ "$json_output" == true ]]; then
                # TODO: Add comment_count like GitHub branch for consistency
                run_tea pr "$number" --output json
            else
                run_tea pr "$number"
                echo ""
                echo "Comments:"
                echo ""
                pr_comments "$number"
            fi
            ;;
    esac
}

pr_status() {
    # Display formatted PR status for current branch
    # Shows warning for merged PRs, confirmation for open PRs, nothing if no PR exists
    local branch
    branch=$(git branch --show-current 2>/dev/null || echo "")
    
    if [[ -z "$branch" ]] || [[ "$branch" == "main" ]]; then
        return 0
    fi
    
    local pr_json
    case "$FORGE_TYPE" in
        github)
            pr_json=$(gh pr view --json number,state 2>/dev/null || echo "")
            ;;
        gitea)
            # tea doesn't have direct branch->PR lookup, fall back to list
            pr_json=$(run_tea pr list --output json 2>/dev/null | \
                jq -c ".[] | select(.head.ref==\"$branch\") | {number, state}" 2>/dev/null || echo "")
            ;;
    esac
    
    if [[ -z "$pr_json" ]]; then
        return 0
    fi
    
    local pr_num pr_state
    pr_num=$(echo "$pr_json" | jq -r '.number' 2>/dev/null)
    pr_state=$(echo "$pr_json" | jq -r '.state' 2>/dev/null)
    
    if [[ -n "$pr_num" ]] && [[ -n "$pr_state" ]]; then
        case "$pr_state" in
            MERGED)
                echo "⚠️  Branch has merged PR #${pr_num} - consider: git checkout main"
                ;;
            OPEN)
                echo "✓ PR #${pr_num} is open"
                ;;
        esac
    fi
}

pr_next_action() {
    local branch default_branch pr_state
    branch=$(git branch --show-current 2>/dev/null || echo "")
    default_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@refs/remotes/origin/@@')

    if [[ -z "$branch" ]] || [[ "$branch" == "$default_branch" ]]; then
        echo "→ Next: Pick an issue and create a feature branch"
        return 0
    fi

    case "$FORGE_TYPE" in
        github)
            pr_state=$(gh pr view --json state --jq '.state' 2>/dev/null || echo "NONE")
            ;;
        gitea)
            pr_state=$(run_tea pr list --output json 2>/dev/null \
                | jq -r ".[] | select(.head.ref==\"$branch\") | .state" 2>/dev/null || echo "NONE")
            ;;
    esac

    case "${pr_state:-NONE}" in
        OPEN)
            if has_unreviewed_llm_commits; then
                echo "→ Next: LLM-authored commits pending your review — stamp Reviewed-By: trailers then push"
            else
                echo "→ Next: Continue work or address review feedback"
            fi
            ;;
        MERGED) echo "→ Next: PR merged — return to $default_branch and start a new branch" ;;
        *)      echo "→ Next: Complete work and create a PR" ;;
    esac
}

pr_comment() {
    local number="${1:-}"
    local text="${2:-}"
    
    # Auto-detect PR if first arg looks like text (doesn't start with digit)
    if [[ -z "$number" ]] || [[ ! "$number" =~ ^[0-9]+$ ]]; then
        # First arg is text, not number
        text="$number"
        number=$(auto_detect_pr) || exit 1
    fi
    
    if [[ -z "$text" ]]; then
        echo "Error: Comment text required" >&2
        exit 1
    fi
    
    # Add agent signature if in agent environment
    if [[ -n "${IN_AGENT_SANDBOX:-}" ]] || [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        text="${text}

---
*🤖 Posted by agent*"
    fi
    
    case "$FORGE_TYPE" in
        github)
            gh pr comment "$number" --body "$text"
            ;;
        gitea)
            run_tea pr comment "$number" "$text"
            ;;
    esac
}

pr_list() {
    local state="open"
    local json_output=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --state) state="$2"; shift 2 ;;
            --json) json_output=true; shift ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    
    case "$FORGE_TYPE" in
        github)
            local args=(--state "$state")
            [[ "$json_output" == true ]] && args+=(--json "number,title,state,headRefName")
            gh pr list "${args[@]}"
            ;;
        gitea)
            local args=(--state "$state")
            [[ "$json_output" == true ]] && args+=(--output json)
            run_tea pr list "${args[@]}"
            ;;
    esac
}

pr_checkout() {
    local number="${1:-}"
    
    # Auto-detect PR if no number provided
    if [[ -z "$number" ]]; then
        number=$(auto_detect_pr) || exit 1
    fi
    
    case "$FORGE_TYPE" in
        github)
            gh pr checkout "$number"
            ;;
        gitea)
            run_tea pr checkout "$number"
            ;;
    esac
}

pr_approve() {
    local number="${1:-}"
    
    # Auto-detect PR if no number provided
    if [[ -z "$number" ]]; then
        number=$(auto_detect_pr) || exit 1
    fi
    
    case "$FORGE_TYPE" in
        github)
            gh pr review "$number" --approve
            ;;
        gitea)
            run_tea pr approve "$number"
            ;;
    esac
}

pr_reviews() {
    local number="${1:-}"
    [[ -n "$number" ]] && shift
    
    # Auto-detect PR if no number provided
    if [[ -z "$number" ]]; then
        number=$(auto_detect_pr) || exit 1
    fi
    
    local json_output=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) json_output=true; shift ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    
    case "$FORGE_TYPE" in
        github)
            if [[ "$json_output" == true ]]; then
                gh api "repos/{owner}/{repo}/pulls/${number}/reviews"
            else
                gh api "repos/{owner}/{repo}/pulls/${number}/reviews" --jq '.[] | "Review #\(.id) by \(.user.login) (\(.state)):\n\(.body)\n---"'
            fi
            ;;
        gitea)
            echo "Error: Review listing not implemented for Gitea" >&2
            exit 1
            ;;
    esac
}

pr_ci() {
    local number="${1:-}"
    [[ -n "$number" ]] && shift

    local workflow=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --timeout) shift 2 ;;
            --workflow) workflow="$2"; shift 2 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done

    if [[ -z "$number" ]]; then
        number=$(auto_detect_pr) || exit 1
    fi

    case "$FORGE_TYPE" in
        github)
            local sha
            sha=$(git rev-parse HEAD)
            local workflow_flag=()
            [[ -n "$workflow" ]] && workflow_flag=(--workflow "$workflow")
            local run_id run_url
            run_id=$(gh run list --commit "$sha" "${workflow_flag[@]}" --limit 1 --json databaseId --jq '.[0].databaseId')
            [[ -z "$run_id" ]] && { echo "No CI run found for sha ${sha} on PR #${number}" >&2; exit 1; }
            run_url=$(gh run view "$run_id" --json url --jq '.url')

            echo "Waiting for run ${run_id} on sha ${sha:0:7} (${run_url})"

            # gh run watch ignores SIGPIPE, making it unsafe to pipe. Redirect its
            # polling stream to a temp file so the caller can pipe pr_ci safely.
            # The polling stream itself is discarded; gh run view prints the final state.
            local tmp
            tmp=$(mktemp)
            gh run watch "$run_id" --exit-status --compact >"$tmp" 2>&1
            local rc=$?
            rm -f "$tmp"
            gh run view "$run_id"
            return $rc
            ;;
        *)
            echo "Error: pr ci not implemented for $FORGE_TYPE" >&2; exit 1 ;;
    esac
}

pr_logs() {
    local number="${1:-}"
    [[ -n "$number" ]] && shift

    local workflow=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --workflow) workflow="$2"; shift 2 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done

    if [[ -z "$number" ]]; then
        number=$(auto_detect_pr) || exit 1
    fi

    case "$FORGE_TYPE" in
        github)
            local branch
            branch=$(gh pr view "$number" --json headRefName --jq '.headRefName')
            local workflow_flag=()
            [[ -n "$workflow" ]] && workflow_flag=(--workflow "$workflow")
            local run_id
            run_id=$(gh run list --branch "$branch" "${workflow_flag[@]}" --limit 1 --json databaseId --jq '.[0].databaseId')
            [[ -z "$run_id" ]] && { echo "No CI run found for PR #${number}" >&2; exit 1; }
            gh run view "$run_id" --log
            ;;
        *)
            echo "Error: pr logs not implemented for $FORGE_TYPE" >&2; exit 1 ;;
    esac
}

pr_comments() {
    local number="${1:-}"
    [[ -n "$number" ]] && shift
    
    # Auto-detect PR if no number provided
    if [[ -z "$number" ]]; then
        number=$(auto_detect_pr) || exit 1
    fi
    
    local json_output=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) json_output=true; shift ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    
    case "$FORGE_TYPE" in
        github)
            if [[ "$json_output" == true ]]; then
                # Return both general and review comments as JSON
                echo '{"general":' && gh api "repos/{owner}/{repo}/issues/${number}/comments" --paginate && echo ',"review":' && gh api "repos/{owner}/{repo}/pulls/${number}/comments" --paginate && echo '}'
            else
                # Fetch general comments (issue/PR conversation)
                local general_comments
                general_comments=$(gh api "repos/{owner}/{repo}/issues/${number}/comments" --paginate --jq '.[] | "[general] @\(.user.login)\n\(.body)\n"' 2>/dev/null || echo "")
                
                # Fetch review comments with threading context
                local review_comments_raw
                review_comments_raw=$(gh api "repos/{owner}/{repo}/pulls/${number}/comments" --paginate 2>/dev/null || echo "[]")
                
                # Build comment lookup map and format with threading context
                local review_comments
                review_comments=$(echo "$review_comments_raw" | jq -r '
                    # Build lookup map: id -> comment
                    (reduce .[] as $c ({}; .[$c.id | tostring] = $c)) as $lookup |
                    # Format each comment with reply context
                    .[] | 
                    (if .in_reply_to_id then 
                        "  ↳ Reply to [\($lookup[.in_reply_to_id | tostring].id)] @\($lookup[.in_reply_to_id | tostring].user.login): \($lookup[.in_reply_to_id | tostring].body[:60])...\n" 
                     else "" end) +
                    "[\(.id)] \(.path):\(.original_start_line // .start_line // .line)-\(.original_line // .line) @\(.user.login)\n\(.body)\n\(.diff_hunk)\n"
                ' 2>/dev/null || echo "")
                
                # Output both
                if [[ -n "$general_comments" ]]; then
                    echo "$general_comments"
                fi
                
                if [[ -n "$review_comments" ]]; then
                    echo "$review_comments"
                fi
                
                # If neither, show message
                if [[ -z "$general_comments" ]] && [[ -z "$review_comments" ]]; then
                    echo "No comments found"
                fi
            fi
            ;;
        gitea)
            echo "Error: Comments not implemented for Gitea" >&2
            exit 1
            ;;
    esac
}

pr_review_reply() {
    local number="${1:-}"
    local comment_id="${2:-}"
    local text="${3:-}"
    
    # Auto-detect PR if first arg looks like comment ID (all digits, typically long)
    if [[ -z "$number" ]] || [[ -z "$comment_id" ]] || [[ -z "$text" ]]; then
        # Try auto-detect if only 2 args provided (comment_id + text)
        if [[ -n "$number" ]] && [[ -n "$comment_id" ]] && [[ -z "$text" ]]; then
            text="$comment_id"
            comment_id="$number"
            number=$(auto_detect_pr) || exit 1
        else
            echo "Error: Usage: forge pr review-reply [PR_NUMBER] COMMENT_ID TEXT" >&2
            exit 1
        fi
    fi
    
    # Add agent signature if in agent environment
    if [[ -n "${IN_AGENT_SANDBOX:-}" ]] || [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        text="${text}

---
*🤖 Posted by agent*"
    fi
    
    case "$FORGE_TYPE" in
        github)
            gh api \
                --method POST \
                "repos/{owner}/{repo}/pulls/${number}/comments" \
                -f body="$text" \
                -F in_reply_to="$comment_id" \
                --jq '"Posted reply to review comment \(.id)"'
            ;;
        gitea)
            echo "Error: Review comment replies not supported for Gitea" >&2
            exit 1
            ;;
    esac
}

# Issue commands
issue_list() {
    local state="open"
    local json_output=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --state) state="$2"; shift 2 ;;
            --json) json_output=true; shift ;;
            --state=*)
                echo "Error: Use space-separated arguments: --state open (not --state=open)" >&2
                exit 1
                ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    
    case "$FORGE_TYPE" in
        github)
            local args=(--state "$state")
            [[ "$json_output" == true ]] && args+=(--json "number,title,state")
            gh issue list "${args[@]}"
            ;;
        gitea)
            local args=(--state "$state")
            [[ "$json_output" == true ]] && args+=(--output json)
            run_tea issue list "${args[@]}"
            ;;
    esac
}

issue_show() {
    local number="$1"
    shift
    
    local json_output=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) json_output=true; shift ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    
    case "$FORGE_TYPE" in
        github)
            local args=("$number")
            [[ "$json_output" == true ]] && args+=(--json "number,title,body,state")
            gh issue view "${args[@]}"
            ;;
        gitea)
            local args=("$number")
            [[ "$json_output" == true ]] && args+=(--output json)
            run_tea issue "$number" "${args[@]}"
            ;;
    esac
}

# Main command router
case "${1:-}" in
    --type)
        # Return forge type for scripts
        echo "$FORGE_TYPE"
        ;;
    doctor)
        shift; doctor "$@"
        ;;
    pr)
        case "${2:-}" in
            create) shift 2; pr_create "$@" ;;
            view) shift 2; pr_view "$@" ;;
            ci) shift 2; pr_ci "$@" ;;
            logs) shift 2; pr_logs "$@" ;;
            status) shift 2; pr_status "$@" ;;
            comment) shift 2; pr_comment "$@" ;;
            comments) shift 2; pr_comments "$@" ;;
            list) shift 2; pr_list "$@" ;;
            checkout) shift 2; pr_checkout "$@" ;;
            approve) shift 2; pr_approve "$@" ;;
            reviews) shift 2; pr_reviews "$@" ;;
            review-reply) shift 2; pr_review_reply "$@" ;;
            next-action) shift 2; pr_next_action "$@" ;;
            *) usage; exit 1 ;;
        esac
        ;;
    issue)
        case "${2:-}" in
            list) shift 2; issue_list "$@" ;;
            show) shift 2; issue_show "$@" ;;
            *) usage; exit 1 ;;
        esac
        ;;
    --help|-h|help|"")
        usage
        ;;
    *)
        echo "Unknown command: $1" >&2
        usage
        exit 1
        ;;
esac
