#!/bin/sh
# GIT_EDITOR for LLM agents.
#
# Git cannot block waiting for interactive input from an agent. This exits
# nonzero to abort the operation, then prints actionable guidance so the
# agent can supply the content via -m or --amend -m instead.

file="$1"

case "$file" in
  */COMMIT_EDITMSG)
    echo "Git wants a commit message. Supply it with: git commit --amend -m '...'"
    ;;
  */rebase-merge/git-rebase-todo)
    echo "Git wants you to edit the rebase todo: $file"
    echo "Edit the file, then run: git rebase --continue"
    ;;
  */MERGE_MSG)
    echo "Git wants a merge message. Supply it with: git commit --amend -m '...'"
    ;;
  *)
    echo "Git wants to edit: $file"
    echo "Write your content to the file, then re-run the git command using -m or -F to skip the editor."
    ;;
esac

exit 1
