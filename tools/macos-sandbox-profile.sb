;; macOS Sandbox Profile for Agent Isolation
;;
;; Inspired by OpenAI Codex and Chrome's sandbox:
;; https://github.com/openai/codex/blob/810ebe0/codex-rs/core/src/seatbelt_base_policy.sbpl
;; https://source.chromium.org/chromium/chromium/src/+/main:sandbox/policy/mac/common.sb
;;
;; Security model: deny-by-default with an explicit read allowlist.
;; (literal "/") is required because the kernel checks the root inode before
;; launching any process under seatbelt — omitting it causes SIGABRT 134 even
;; when all real filesystem directories are covered. All other read access is
;; restricted to known OS and user directories; credential paths are denied last
;; so they override the broader allowlist entries that cover their parents.

(version 1)

(deny default)

;; ==============================================================================
;; Process
;; ==============================================================================

(allow process-exec)
(allow process-fork)
(allow signal (target same-sandbox))
(allow user-preference-read)
(allow process-info* (target same-sandbox))

;; ==============================================================================
;; Devices
;; ==============================================================================

(allow file-write-data
  (require-all
    (path "/dev/null")
    (vnode-type CHARACTER-DEVICE)))

;; PTY support for interactive shells
(allow pseudo-tty)
(allow file-read* file-write* file-ioctl (literal "/dev/ptmx"))
(allow file-read* file-write*
  (require-all
    (regex #"^/dev/ttys[0-9]+")
    (extension "com.apple.sandbox.pty")))
;; PTYs created before entering seatbelt may lack the extension
(allow file-ioctl (regex #"^/dev/ttys[0-9]+"))

;; ==============================================================================
;; Sysctls
;; ==============================================================================

(allow sysctl-read
  (sysctl-name "hw.activecpu")
  (sysctl-name "hw.busfrequency_compat")
  (sysctl-name "hw.byteorder")
  (sysctl-name "hw.cacheconfig")
  (sysctl-name "hw.cachelinesize_compat")
  (sysctl-name "hw.cpufamily")
  (sysctl-name "hw.cpufrequency_compat")
  (sysctl-name "hw.cputype")
  (sysctl-name "hw.l1dcachesize_compat")
  (sysctl-name "hw.l1icachesize_compat")
  (sysctl-name "hw.l2cachesize_compat")
  (sysctl-name "hw.l3cachesize_compat")
  (sysctl-name "hw.logicalcpu_max")
  (sysctl-name "hw.machine")
  (sysctl-name "hw.memsize")
  (sysctl-name "hw.ncpu")
  (sysctl-name "hw.nperflevels")
  (sysctl-name-prefix "hw.optional.arm.")
  (sysctl-name-prefix "hw.optional.armv8_")
  (sysctl-name "hw.packages")
  (sysctl-name "hw.pagesize_compat")
  (sysctl-name "hw.pagesize")
  (sysctl-name "hw.physicalcpu")
  (sysctl-name "hw.physicalcpu_max")
  (sysctl-name "hw.tbfrequency_compat")
  (sysctl-name "hw.vectorunit")
  (sysctl-name "kern.argmax")
  (sysctl-name "kern.hostname")
  (sysctl-name "kern.maxfilesperproc")
  (sysctl-name "kern.maxproc")
  (sysctl-name "kern.osproductversion")
  (sysctl-name "kern.osrelease")
  (sysctl-name "kern.ostype")
  (sysctl-name "kern.osvariant_status")
  (sysctl-name "kern.osversion")
  (sysctl-name "kern.secure_kernel")
  (sysctl-name "kern.usrstack64")
  (sysctl-name "kern.version")
  (sysctl-name "sysctl.proc_cputype")
  (sysctl-name "vm.loadavg")
  (sysctl-name-prefix "hw.perflevel")
  (sysctl-name-prefix "kern.proc.pgrp.")
  (sysctl-name-prefix "kern.proc.pid.")
  (sysctl-name-prefix "net.routetable."))

;; Misclassified as write — Java reads CPU info via buffer passed to sysctl
(allow sysctl-write
  (sysctl-name "kern.grade_cputype"))

;; ==============================================================================
;; IOKit / Mach
;; ==============================================================================

(allow iokit-open
  (iokit-registry-entry-class "RootDomainUserClient"))

(allow mach-lookup
  (global-name "com.apple.system.opendirectoryd.libinfo")
  (global-name "com.apple.PowerManagement.control")
  ;; DNS resolution on macOS goes through mDNSResponder via Mach IPC.
  ;; Without this, (allow network*) is insufficient for hostname lookups.
  (global-name "com.apple.mDNSResponder"))

;; ==============================================================================
;; IPC
;; ==============================================================================

;; Python multiprocessing (SemLock) and SQLite shared memory cache
(allow ipc-posix-sem)
(allow ipc-posix-shm)

;; ==============================================================================
;; Network
;; ==============================================================================

(allow network*)

;; network* covers TCP/UDP but not the mDNSResponder socket or netsrc control.
;; Derived from chromium/src/sandbox/policy/mac/network.sb.
(allow network-outbound
  (control-name "com.apple.netsrc")
  (literal "/private/var/run/mDNSResponder"))

;; AF_SYSTEM/SYSPROTO_CONTROL and AF_ROUTE are separate from network*.
(allow system-socket
  (require-all (socket-domain AF_SYSTEM) (socket-protocol 2))
  (socket-domain AF_ROUTE))

;; DNS configuration, TLS cert validation, and network relay via Mach services.
;; Derived from chromium/src/sandbox/policy/mac/network.sb.
(allow mach-lookup
  (global-name "com.apple.SystemConfiguration.DNSConfiguration")
  (global-name "com.apple.SystemConfiguration.configd")
  (global-name "com.apple.networkd")
  (global-name "com.apple.trustd.agent")
  (global-name "com.apple.ocspd")
  (global-name "com.apple.nehelper")
  (global-name "com.apple.system.notification_center")
  ;; TLS certificate chain validation via Security framework.
  (global-name "com.apple.SecurityServer")
  ;; _CS_DARWIN_USER_CACHE_DIR lookup used by libcurl and Security framework.
  (global-name "com.apple.bsd.dirhelper")
  (global-name "com.apple.system.opendirectoryd.membership"))

;; ==============================================================================
;; File Read
;; ==============================================================================

;; (literal "/") is mandatory: the kernel reads the root inode before launching
;; any sandboxed process. Without it, sandbox-exec aborts with SIGABRT 134 even
;; when every visible directory under / is explicitly allowed.
(allow file-read*
  (literal "/")
  (subpath "/System")
  (subpath "/usr")
  (subpath "/bin")
  (subpath "/sbin")
  (subpath "/Library")
  (subpath "/private")
  ;; /etc -> /private/etc on macOS; sandbox-exec does string-prefix matching
  ;; so /etc paths do not match (subpath "/private") and must be listed separately.
  (subpath "/etc")
  (subpath "/tmp")
  (subpath "/dev")
  (subpath "/nix")
  (subpath "/opt")
  (subpath "/Applications")
  ;; /Users must be readable so tools can stat the parent of $HOME.
  (literal "/Users")
  (literal (param "HOME_DIR"))
  (subpath (param "PROJECT_DIR")))

;; DNS resolution reads /etc/resolv.conf and /etc/hosts through a tangle of
;; symlinks. sandbox-exec matches string prefixes on the path as-presented
;; (without resolving symlinks), so both the symlink paths (/var/run, /etc)
;; and the canonical paths (/private/var/run, /private/etc) must be allowed.
;; (subpath "/private") and (subpath "/etc") above cover the canonical and
;; /etc-prefixed forms; these cover the /var symlink tree.
;; Derived from chromium/src/sandbox/policy/mac/network.sb.
(allow file-read*
  (literal "/var")
  (literal "/var/run")
  (literal "/var/run/resolv.conf"))

;; Home directory read rules are appended dynamically by macos-sandbox.sh
;; (only paths that exist, to avoid SIGABRT on missing subpath targets).
;; macos-sandbox.sh appends (allow file-read* (subpath (param "HOME_SSH")))
;; when AGENT_SANDBOX_SSH=true to restore SSH access for git operations.

;; ==============================================================================
;; File Write
;; ==============================================================================

;; Both /tmp and /private/tmp needed — /tmp is a symlink to /private/tmp.
;; Home subdirectory write rules are appended dynamically by macos-sandbox.sh
;; after existence checks; sandbox-exec SIGABRTs on (subpath) of missing paths.
(allow file-write*
  (subpath (param "PROJECT_DIR"))
  (subpath (param "WORK_DIR"))
  (subpath (param "TMPDIR"))
  (subpath "/tmp")
  (subpath "/private/tmp"))

;; Prevent agents from overriding git identity. (literal) is more specific
;; than (subpath), so this deny overrides the PROJECT_DIR write allowance above.
(deny file-write* (literal (param "GIT_CONFIG")))

;; ==============================================================================
;; Extensibility
;; ==============================================================================

;; Home subdirectory write rules and EXTRA_PATHS appended here by macos-sandbox.sh
